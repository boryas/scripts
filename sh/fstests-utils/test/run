#!/usr/bin/env bash
SCRIPT=$(readlink -f "$0")
DIR=$(dirname "$SCRIPT")
CMD_ROOT=$(dirname "$DIR")
SH_ROOT=$(dirname $CMD_ROOT)

source "$SH_ROOT/boilerplate.sh"

if [ $# -ne 1 ]; then
	echo $#
	_usage
fi

patch_name=$1
shift

# Phase timing: capture wall-clock at each major boundary so the run
# reports build / provision / dispatch elapsed at the end.  Useful for
# "is the slow part the build or the tests" diagnostics.
run_start_s=$(date +%s)
phase_start_s=$run_start_s
phase_log=()
phase_end() {
	local name=$1
	local now=$(date +%s)
	local elapsed=$((now - phase_start_s))
	phase_log+=("$name:$elapsed")
	phase_start_s=$now
	printf '[%s] phase done: %-10s %4dm %02ds\n' \
		"$(date +%H:%M:%S)" "$name" "$((elapsed/60))" "$((elapsed%60))" >&2
}

# Maximum per-task budget envelope.  Sets wq-ssh's local-watchdog
# ceiling; per-test budgets (encoded in the JSONL task stream) enforce
# the real deadline via `timeout(1)` inside the cmd template.  Bumped
# to 90m to accommodate the 1h operator override on btrfs/187 and
# generic/166 -- those tests were previously skipped via schedule:
# persistent_hang and now get a real chance to finish.
max_task_timeout="${MAX_TASK_TIMEOUT:-90m}"

# Source kernel tree to build / boot from.  Defaults to the user's main
# repo.  The for-next cron sets this to ~/repos/linux-fnext so the
# automation runs against a dedicated worktree without touching the
# user's checkout.
kernel_src="${KERNEL_SRC:-$HOME/repos/linux}"
export KERNEL_SRC="$kernel_src"

# Worker backend.  `local-vm` drives the v0..v4 qemu fleet on this host;
# `cloud` drives instances under a systemd-managed scope.  Each backend
# is a directory of one-script-per-verb under workers/<name>/.
workers="${WORKERS:-local-vm}"
B="$CMD_ROOT/workers/$workers"
if [ ! -x "$B/up" ]; then
	echo "no such worker backend: $workers ($B)" >&2
	exit 1
fi

cd "$kernel_src"
# If HEAD is detached, the caller has already positioned us at a
# specific commit (e.g. cron/for-next pins to `btrfs/for-next`'s
# current tip).  Don't "switch to $patch_name" -- that resolves to
# the local branch, which may lag the remote, and would roll the
# worktree back to a different commit than the caller chose.
# When HEAD is on a branch, switch to $patch_name as before, with
# a detach fallback for the "branch is held by another worktree"
# case (e.g. cron's worktree wants for-next while the main repo
# already has the local for-next branch checked out).
if git symbolic-ref -q HEAD >/dev/null; then
	if ! git checkout "$patch_name" 2>/dev/null; then
		echo "branch $patch_name is claimed by another worktree; detaching at it instead"
		git checkout --detach "$patch_name"
	fi
fi
make olddefconfig
# tarzst-pkg builds the kernel and packages it into
# $KERNEL_SRC/linux-<release>-<arch>.tar.zst.  Local-vm boots from
# arch/x86/boot/bzImage and ignores the tarball; cloud workers/cloud/up
# globs the tarball and ships it onto each droplet.  Always producing it
# avoids "wrong build target" footguns when switching backends.
make -j$(nproc) tarzst-pkg
hash=$(git log -1 --pretty=format:"%h")
# Per-run unique id: kernel sha + start timestamp.  Lets the nightly
# cron run repeatedly against the same for-next sha (when upstream
# hasn't moved) without overwriting prior digests; flake/regression
# detection wants distinct data points, not "latest result for sha".
run_id="${hash}-$(date -u +%Y%m%dT%H%M%SZ)"
phase_end build

out_dir=~/fstests-results/$patch_name
mkdir -p $out_dir
out_file="$out_dir/$run_id"
# Per-run dir where the artifacts step rsyncs failure files (.out.bad,
# .full, .dmesg) off the workers after dispatch.
details_dir="$out_dir/$run_id.details"

# Dispatcher binary.  WQ_SSH_BIN lets cron / the for-next worktree
# override the path without editing this file.  Build with
# `cargo build --release` inside ~/repos/wq-ssh; the default points at
# the release artifact.
wq_ssh="${WQ_SSH_BIN:-$HOME/repos/wq-ssh/target/release/wq-ssh}"
if [ ! -x "$wq_ssh" ]; then
	echo "wq-ssh binary not found at $wq_ssh" >&2
	echo "  build with: (cd ~/repos/wq-ssh && cargo build --release)" >&2
	echo "  or override WQ_SSH_BIN" >&2
	exit 1
fi

# Each fstests phase runs inside its own transient systemd scope, i.e.
# its own cgroup.  On any exit -- clean completion, error, external
# SIGTERM/SIGINT -- the trap stops both scopes; the kernel kills the
# entire cgroup atomically via cgroup.kill, so no descendant (e.g. a
# para-fstests worker subshell, an in-flight ssh) survives as an
# orphan.  Then the backend's `down` tears down workers.
#
# This is the strong teardown guarantee for cloud (where leaked
# droplets cost money); local-vm benefits too.  The scope-kill is
# what prevents the "zombie para-fstests pounding deleted IPs for
# an hour" failure mode that bit us earlier.
para_scope="fstests-dispatch-$$"
trap '
	systemctl --user stop "$para_scope.scope"  2>/dev/null || true
	"$B/down"
' EXIT INT TERM

"$B/down"
"$B/up"
vms=($("$B/list"))
all_vms=${vms[*]}
echo "running fstests on: $all_vms (per-task timeouts derived from history; max envelope: $max_task_timeout)"
for vm in $vms; do
	"$B/ready" "$vm"
done
phase_end provision

# Per-test operator metadata: consolidated in fstests-utils/tests.yaml,
# queried via `rcli fstests-utils tests {slow,schedule,budgets,meta}`.
# schedule:persistent_hang means "don't even try"; the test gets a
# synthetic timeout TaskDone appended to the JSONL after dispatch so
# the digest still has an entry for it.
persistent_hang_tests=$(rcli fstests-utils tests schedule persistent_hang)
slow_tests=$(rcli fstests-utils tests slow)

# Compute the explicit parallel-phase test list on the controller.
# Ask the first worker for the full -g auto list, then drop any tests
# scheduled persistent_hang or para_skip.  wq-ssh consumes the
# resulting list verbatim; no dispatcher-side filtering needed.
para_tests=$(ssh "${vms[0]}" 'cd /mnt/repos/fstests; sudo ./check -E EXCLUDE -n -g auto' \
	| grep -oE '^[a-zA-Z]+/[0-9]+' | grep -v expunged | sort -u)
# (grep -oE strips trailing whitespace; check -n pads test names with
#  spaces for column-alignment, which breaks naive ^...$ regex matches.)
nbefore=$(echo "$para_tests" | wc -l)
if [ -n "$persistent_hang_tests" ]; then
	para_tests=$(comm -23 <(echo "$para_tests") <(echo "$persistent_hang_tests" | sort -u))
fi
nafter=$(echo "$para_tests" | wc -l)
echo "dispatch test list: $nbefore -> $nafter tests after filtering"

# Slow-first dispatch: tests tagged slow:true in tests.yaml get the
# front of the queue so the long tail starts running on its own worker
# while the short tests churn through later.
if [ -n "$slow_tests" ]; then
	slow_in_tests=$(comm -12 <(echo "$slow_tests" | sort -u) <(echo "$para_tests" | sort -u))
	rest=$(comm -23 <(echo "$para_tests" | sort -u) <(echo "$slow_tests" | sort -u))
	para_tests=$(printf '%s\n%s\n' "$slow_in_tests" "$rest" | grep -v '^$')
	echo "slow-first: $(echo "$slow_in_tests" | grep -c .) slow tests dispatched first"
fi

# Save the resolved YAML + task list next to the JSONL for forensic
# value (you can eyeball what the run actually saw).
#
# Each task line carries its own `timeout:` field, derived from
# tests.yaml + history.  wq-ssh exports that as $TASK_TIMEOUT on the
# worker; the cmd template uses it to drive a per-test timeout(1)
# invocation.
#
# cmd places sudo *outside* timeout so timeout owns the process group
# and SIGTERM reaches ./check.  The opposite arrangement (timeout
# outside sudo) leaks because sudo creates a fresh session.
run_cfg="$out_file.yaml"
run_tasks="$out_file.tasks"
echo "$para_tests" | rcli fstests-utils tests budgets "$patch_name" > "$run_tasks"
cat > "$run_cfg" <<EOF
workers:
$(printf '  - %s\n' "${vms[@]}")
cmd: 'cd /mnt/repos/fstests && sudo TERM=dumb timeout -k 30s "\$TASK_TIMEOUT" ./check -E EXCLUDE {}'
task_timeout: $max_task_timeout
EOF

# Dispatch: single phase, per-task budgets, in a cgroup so the trap can
# teardown every descendant on exit.  JSONL goes to $out_file;
# digest/run reads it.
systemd-run --user --scope --quiet --unit="$para_scope" \
	--property=TimeoutStopSec=10s \
	--description="fstests run ($patch_name @ $hash)" \
	-- "$wq_ssh" "$run_cfg" \
	< "$run_tasks" \
	| tee "$out_file" >/dev/null
phase_end dispatch

# Rsync failure artifacts off each worker for any failed/timed-out test.
# Post-pass: fstests' .dmesg file persists on disk on the worker, so we
# don't lose dmesg context by waiting until the whole dispatch is done.
rcli fstests-utils artifacts "$out_file" "$details_dir"

# Synthesize task_done events for schedule:persistent_hang tests so
# the digest sees them with verdict timeout.  No actual dispatch
# happens; saves the cost of waiting on tests we know don't complete.
# worker="preknown" so the digest's synthetic-event check can
# recognize them.
synth_ts=$(date -u +%FT%T.000Z)
for tst in $persistent_hang_tests; do
	printf '{"event":"task_done","ts":"%s","worker":"preknown","task":"%s","exit":124,"signal":null,"timeout":true,"dur":0.0,"stdout":"","stdout_truncated":false,"stderr":"synthetic: schedule:persistent_hang via tests.yaml","stderr_truncated":false,"transport_error":null}\n' \
		"$synth_ts" "$tst" >> "$out_file"
done

# Produce the structured digest for long-term tracking.  Fold into the
# branch's history.json so cross-run queries see this run.
echo
echo "=== writing structured digest ==="
rcli fstests-utils digest "$patch_name" "$run_id"
rcli fstests-utils state "$patch_name"

# Push to s1: ships current scripts + this branch's digests/details, then
# re-renders the site directly into the nginx-served dir.  Replaces the
# old "render locally, rsync HTML" path; s1 is now the canonical store.
echo
echo "=== publishing to s1 ==="
rcli fstests-utils publish "$patch_name"

echo
echo "=== run timing ==="
for entry in "${phase_log[@]}"; do
	printf '  %-12s %4dm %02ds\n' "${entry%:*}" "$((${entry#*:}/60))" "$((${entry#*:}%60))"
done
total=$(( $(date +%s) - run_start_s ))
printf '  %-12s %4dm %02ds\n' "TOTAL" "$((total/60))" "$((total%60))"
