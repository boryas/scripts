#!/usr/bin/env bash
# fstests-utils adhoc <test> [test...]
#
# Run a specific list of tests in parallel across whatever workers are
# currently up.  No build, no up/down, no digest -- just dispatch via
# wq-ssh and dump the resulting JSONL to stdout.  Useful for:
#   - reproducing a flake quickly
#   - validating a single fix
#   - dispatching to an existing fleet without going through test/run
#
# Honors:
#   $WORKERS    worker backend (default local-vm)
#   $TIMEOUT    per-test timeout (default 30m -- closer to retry semantics
#               than parallel-phase 8m; assumes you're targeting flakes or
#               specific tests, not a full sweep)
#   $HOSTS      explicit comma-separated subset of hosts to use, e.g.
#               HOSTS=fstests@1.2.3.4,fstests@5.6.7.8 for the "run on the
#               idle workers while a serial run uses one of them" case.
#               Defaults to "$B/list".
#   $WQ_SSH_BIN override the wq-ssh binary path (default
#               ~/repos/wq-ssh/target/release/wq-ssh).

SCRIPT=$(readlink -f "$0")
DIR=$(dirname "$SCRIPT")
CMD_ROOT=$(dirname "$DIR")
SH_ROOT=$(dirname "$CMD_ROOT")
source "$SH_ROOT/boilerplate.sh"

if [ $# -lt 1 ]; then
	_usage
fi

timeout="${TIMEOUT:-30m}"
workers="${WORKERS:-local-vm}"
B="$CMD_ROOT/workers/$workers"
if [ ! -x "$B/list" ]; then
	echo "no such worker backend: $workers ($B)" >&2
	exit 1
fi

# Resolve host list: explicit $HOSTS wins, otherwise $B/list.
if [ -n "${HOSTS:-}" ]; then
	hosts=$(echo "$HOSTS" | tr ',' ' ')
else
	hosts=$("$B/list" | tr '\n' ' ')
fi

if [ -z "$hosts" ]; then
	echo "no workers available.  start them first: $B/up" >&2
	exit 1
fi

tests=("$@")
nhosts=$(echo "$hosts" | wc -w)
echo "adhoc: ${tests[*]}" >&2
echo "       across $nhosts workers (per-test timeout: $timeout)" >&2
echo "       hosts: $hosts" >&2
echo >&2

wq_ssh="${WQ_SSH_BIN:-$HOME/repos/wq-ssh/target/release/wq-ssh}"
if [ ! -x "$wq_ssh" ]; then
	echo "wq-ssh binary not found at $wq_ssh" >&2
	echo "  build with: (cd ~/repos/wq-ssh && cargo build --release)" >&2
	exit 1
fi

cfg=$(mktemp --suffix=.yaml)
trap 'rm -f "$cfg"' EXIT

cat > "$cfg" <<EOF
workers:
$(printf '  - %s\n' $hosts)
cmd: 'cd /mnt/repos/fstests && sudo TERM=dumb timeout -k 30s $timeout ./check -E EXCLUDE {}'
no_remote_timeout: true
task_timeout: $timeout
task_grace: 30s
dead_threshold: 3
probe_interval: 5s
EOF

printf '%s\n' "${tests[@]}" | "$wq_ssh" "$cfg"
