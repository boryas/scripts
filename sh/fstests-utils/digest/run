#!/usr/bin/env python3
"""
fstests-utils digest <branch> <sha>

Parses ~/fstests-results/<branch>/<sha> [+ .retry] into <sha>.json with
the schema documented in the long-term-tracking plan.

Two input formats are auto-detected:

  1. JSONL (wq-ssh era): one TaskDone event per line.  Per-test result is
     derived from the event's exit/timeout/transport_error fields plus a
     "Failures:" / "Not run:" / "[not run]" scan of the captured stdout.
  2. Line grammar (legacy para-fstests era): paired "vm tst Ran: tst" /
     "Failures: tst" / "Not run: tst" / "vm tst Timeout: tst" lines, with
     "Failures:"/"Not run:" matched to the most recent pending Ran: by
     test name.  Kept so backfill of historical runs still works.
"""

import json
import os
import re
import sys
from datetime import datetime, timezone

USAGE = "usage: fstests-utils digest <branch> <sha>"

# VM identifier is whatever ssh target para-fstests was given: v0..v4 for
# local-vm, fstests@<ip> for cloud, anything else.  We just require non-
# whitespace.  The ordering below (RAN/TIMEOUT/FAIL/NOTRUN before START)
# ensures the permissive START_RE doesn't capture "Failures: t/N" /
# "Not run: t/N" by mistake -- those match their specific regex first.
#
# Ran/Timeout lines optionally end with " dur=Ns" (the wall-clock
# duration ssh-one.sh records).  Older logs without it still match.
RAN_RE      = re.compile(r"^(\S+) (\S+/\d+) Ran: (\S+/\d+)(?: dur=(\d+)s)?$")
TIMEOUT_RE  = re.compile(r"^(\S+) (\S+/\d+) Timeout: (\S+/\d+)(?: dur=(\d+)s)?$")
START_RE    = re.compile(r"^(\S+) (\S+/\d+)$")
# FAIL_RE / NOTRUN_RE accept an optional " dur=Ns" tail too, defensive
# against an earlier ssh-one.sh bug that appended dur after $res (the
# multi-line Ran:+Failures: blob).  The Ran: line carries the canonical
# dur; this is just so a stray dur on the refinement line doesn't
# silently misverdict the test.
FAIL_RE     = re.compile(r"^Failures: (\S+/\d+)(?: dur=\d+s)?$")
NOTRUN_RE   = re.compile(r"^Not run: (\S+/\d+)(?: dur=\d+s)?$")
# Per-test skip reason emitted by ssh-one.sh as ./check's verbatim
# "<test>  [not run] <reason>" line.  Captured for the most recent
# pending Ran: by test name (skips also get a Ran: line first).
SKIP_REASON_RE = re.compile(r"^(\S+/\d+)\s+\[not run\]\s*(.+)$")

# Per-test patterns scanned inside one TaskDone's captured stdout when
# parsing JSONL.  Multiline so they match lines anywhere in the blob.
JSONL_FAIL_RE     = re.compile(r"^Failures: ", re.M)
JSONL_NOTRUN_RE   = re.compile(r"^Not run: ",  re.M)
# Synthetic events emitted by test/run for PARA_SKIP / PERSISTENT_HANGS
# tests (see the synthetic-skip block there) use these worker names so
# the digest can recognize them; the value lands in the per-test "vm"
# field unchanged.
SYNTHETIC_WORKERS = {"preknown", "_skip"}


def is_jsonl(path):
    """Peek the first non-empty line; JSONL if it parses as an object
    with an `event` field, else legacy line grammar."""
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                except json.JSONDecodeError:
                    return False
                return isinstance(obj, dict) and "event" in obj
    except OSError:
        return False
    return False


def extract_jsonl(path):
    """JSONL parser.  Same return shape as extract()."""
    out = {}
    with open(path) as f:
        for i, line in enumerate(f, 1):
            line = line.strip()
            if not line:
                continue
            try:
                ev = json.loads(line)
            except json.JSONDecodeError as e:
                print(f"warn: {path}:{i}: not JSON: {e}", file=sys.stderr)
                continue
            if ev.get("event") != "task_done":
                continue
            test   = ev["task"]
            worker = ev["worker"]
            stdout = ev.get("stdout", "")
            dur_f  = ev.get("dur")
            dur    = int(round(dur_f)) if isinstance(dur_f, (int, float)) else None

            # Verdict derivation order matters: timeout dominates other
            # signals because the remote process tree was killed mid-run,
            # so any "Failures:"/"Not run:" already in stdout is moot.
            if ev.get("timeout"):
                result = "timeout"
            elif ev.get("transport_error"):
                # Treat ssh transport failures like timeouts: the test
                # didn't really run, so retry will rerun it.  Verdict
                # logic in verdict() then collapses on the retry result.
                result = "timeout"
            elif JSONL_FAIL_RE.search(stdout):
                result = "fail"
            elif JSONL_NOTRUN_RE.search(stdout):
                result = "skip"
            elif ev.get("exit") == 0:
                result = "pass"
            else:
                # Non-zero exit with no Failures:/Not run: in stdout --
                # most likely an early ./check error (bad option, EXCLUDE
                # file missing, ...).  Treat as fail so it shows up.
                result = "fail"

            entry = {"result": result, "vm": worker, "dur": dur}
            if result == "skip":
                m = re.search(
                    rf"^{re.escape(test)}\s+\[not run\]\s*(.+)$",
                    stdout, re.M)
                if m:
                    entry["skip_reason"] = m.group(1).strip()
            out[test] = entry
    return out


def extract(path):
    """Return {test_name: {"result": str, "vm": str, "dur": int|None,
                           "skip_reason": str|None (skips only)}}.
    result ∈ {pass, fail, skip, timeout}.  dur is wall-clock seconds
    captured from "dur=Ns" tail on Ran/Timeout lines; None for older
    logs without the suffix.  skip_reason is the text after "[not run]"
    from ./check; present only when result == "skip"."""
    out = {}
    # pending: (vm, test, result, dur, skip_reason)
    pending = None
    with open(path) as f:
        for line in f:
            line = line.rstrip("\n")

            m = RAN_RE.match(line)
            if m:
                if pending is not None:
                    flush(out, pending)
                vm, test, _, dur = m.groups()
                pending = (vm, test, "pass", int(dur) if dur else None, None)
                continue

            m = TIMEOUT_RE.match(line)
            if m:
                if pending is not None:
                    flush(out, pending)
                vm, test, _, dur = m.groups()
                out[test] = {"result": "timeout", "vm": vm,
                             "dur": int(dur) if dur else None}
                pending = None
                continue

            m = FAIL_RE.match(line)
            if m and pending is not None and m.group(1) == pending[1]:
                pending = (pending[0], pending[1], "fail", pending[3], pending[4])
                continue

            m = NOTRUN_RE.match(line)
            if m and pending is not None and m.group(1) == pending[1]:
                pending = (pending[0], pending[1], "skip", pending[3], pending[4])
                continue

            m = SKIP_REASON_RE.match(line)
            if m and pending is not None and m.group(1) == pending[1]:
                pending = (pending[0], pending[1], pending[2], pending[3],
                           m.group(2).strip())
                continue

            m = START_RE.match(line)
            if m:
                # Bare "vm test" start line; flush prior pending if it exists.
                if pending is not None:
                    flush(out, pending)
                    pending = None
                continue
    if pending is not None:
        flush(out, pending)
    return out


def flush(out, pending):
    """Write a finalized pending tuple into out."""
    vm, test, result, dur, reason = pending
    entry = {"result": result, "vm": vm, "dur": dur}
    if result == "skip" and reason:
        entry["skip_reason"] = reason
    out[test] = entry


def verdict(result):
    """Single-pass verdict.  Result is the only signal we have; no
    cross-phase combination since the retry phase was retired (#84).
    Verdicts: pass, skip, fail, timeout.  (Cross-run flake detection
    lives in `results flakes` -- task #88.)"""
    return result


def main():
    if len(sys.argv) != 3:
        print(USAGE, file=sys.stderr)
        sys.exit(22)

    branch, sha = sys.argv[1], sys.argv[2]
    results_dir = os.path.expanduser(f"~/fstests-results/{branch}")
    run_file = os.path.join(results_dir, sha)
    out_file = os.path.join(results_dir, f"{sha}.json")

    if not os.path.isfile(run_file):
        print(f"FAIL: no result file: {run_file}", file=sys.stderr)
        sys.exit(1)

    results = (extract_jsonl(run_file) if is_jsonl(run_file)
               else extract(run_file))

    tests = {}
    for name, entry in results.items():
        out_entry = {"run": entry, "verdict": verdict(entry["result"])}
        tests[name] = out_entry

    # Summary counts.
    counts = {k: 0 for k in ("pass", "skip", "fail", "timeout")}
    for t in tests.values():
        counts[t["verdict"]] = counts.get(t["verdict"], 0) + 1
    counts["total"] = len(tests)

    ended_ts = os.stat(run_file).st_mtime
    ended_iso = datetime.fromtimestamp(ended_ts, tz=timezone.utc).astimezone().isoformat()

    doc = {
        "version": 1,
        "sha": sha,
        "branch": branch,
        "ended": ended_iso,
        "summary": counts,
        "tests": tests,
    }

    with open(out_file, "w") as f:
        json.dump(doc, f, indent=2, sort_keys=True)
        f.write("\n")
    print(f"wrote {out_file}")


if __name__ == "__main__":
    main()
