.test-grid a { white-space: nowrap; }
/* Per-failure inline blocks on the per-run page.  One <details> per
   failing test under the fail/hang/flake group, carrying that test's
   .out.bad + first dmesg splat.  Anchor ids are "t-<group>-<num>" so
   verdict pills on other pages can deep-link straight into the right
   test's expanded artifacts. */
details.failure { margin: 0.3em 0 0.3em 1em; padding-left: 0.8em;
                  border-left: 2px solid #eee; }
