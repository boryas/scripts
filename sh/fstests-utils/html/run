#!/usr/bin/env python3
"""
fstests-utils html [branch]

Generate static HTML dashboards from the JSON digests in
~/fstests-results/<branch>/.  Pages produced under ~/fstests-results/html/:

    index.html                          branch picker
    <branch>/index.html                 latest run + breakages-in-last-N
    <branch>/tests/<group>/<num>.html   per-test verdict timeline

If $HTML_RSYNC_TARGET is set (e.g. "s1:/usr/local/share/site/static/fstests/"),
also rsyncs the html dir there at the end.
"""

import json
import os
import subprocess
import sys
from pathlib import Path

import yaml
from jinja2 import Environment, BaseLoader, select_autoescape

HOME = Path.home()
RESULTS_DIR = HOME / "fstests-results"
HTML_DIR = Path(os.environ.get("HTML_DIR") or RESULTS_DIR / "html")
LAST_N_RUNS = 10  # for the "breakages in last N runs" section
HISTORY_LIMIT = 30  # rows on per-test history page

# Verdicts we care about for "broken" status.  flake & flake-from-timeout
# are reported separately -- worth surfacing but not a clean fail.
# Post-#84 we emit just {pass, skip, fail, timeout}.  Pre-#84 digests
# in history.json carry the older richer vocab; we keep recognizing
# both so the page renders correctly across the rename boundary.
BAD_VERDICTS = {"fail", "timeout", "persistent-fail", "persistent-hang", "hang"}
FLAKE_VERDICTS = {"flake", "flake-from-timeout"}
# Verdicts considered "the test ran cleanly" for known-failure transition
# detection.  If a listed-as-known test produces one of these, it's an
# improvement we want to surface.
GOOD_VERDICTS = {"pass", "skip"}

# tests.yaml lives alongside this script's parent (the fstests-utils/
# root).  Loaded once at startup; missing file is fine.  Holds all
# per-test operator metadata (schedule, slow, plus investigation
# notes); we project out just the entries with investigation notes
# (`category` set) for the known-failures bucket on the per-run page.
TESTS_PATH = Path(__file__).resolve().parent.parent / "tests.yaml"


def load_known_failures():
    """Return {test_name: {category, status, explanation, ...}} for
    every test in tests.yaml that has investigation notes (i.e. a
    `category` field).  Empty dict if the file is missing or
    unparseable -- the page still renders, it just won't have the
    known-failures bucket."""
    if not TESTS_PATH.exists():
        return {}
    try:
        with open(TESTS_PATH) as f:
            data = yaml.safe_load(f) or {}
    except yaml.YAMLError:
        return {}
    if not isinstance(data, dict):
        return {}
    return {
        tname: meta
        for tname, meta in data.items()
        if isinstance(meta, dict) and meta.get("category")
    }


KNOWN_FAILURES = load_known_failures()


def adjusted_summary(digest):
    """Return a copy of the digest's summary counts with known-failure
    tests subtracted from the fail/hang totals and surfaced as a new
    `known` count.  Unlisted tests are unchanged -- the headline
    fail/hang numbers then reflect *unknown* problems only."""
    s = dict(digest.get("summary", {}))
    if not KNOWN_FAILURES:
        return s
    tests = digest.get("tests", {})
    known_fail = known_timeout = 0
    for tname, meta in KNOWN_FAILURES.items():
        v = tests.get(tname, {}).get("verdict")
        if v in ("fail", "persistent-fail"):
            known_fail += 1
        elif v in ("hang", "persistent-hang", "timeout"):
            known_timeout += 1
    s["fail"] = max(0, s.get("fail", 0) - known_fail)
    s["persistent-fail"] = max(0, s.get("persistent-fail", 0))
    s["hang"] = max(0, s.get("hang", 0) - known_timeout)
    s["persistent-hang"] = max(0, s.get("persistent-hang", 0))
    s["timeout"] = max(0, s.get("timeout", 0))  # post-#84 vocab
    s["known"] = known_fail + known_timeout
    return s

CSS = """\
