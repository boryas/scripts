#!/usr/bin/env python3
"""
fstests-utils html [branch]

Generate static HTML dashboards from the JSON digests in
~/fstests-results/<branch>/.  Pages produced under ~/fstests-results/html/:

    index.html                          branch picker
    <branch>/index.html                 latest run + breakages-in-last-N
    <branch>/tests/<group>/<num>.html   per-test verdict timeline

If $HTML_RSYNC_TARGET is set (e.g. "s1:/usr/local/share/site/static/fstests/"),
also rsyncs the html dir there at the end.
"""

import json
import os
import subprocess
import sys
from pathlib import Path

from jinja2 import Environment, BaseLoader, select_autoescape

HOME = Path.home()
RESULTS_DIR = HOME / "fstests-results"
HTML_DIR = RESULTS_DIR / "html"
LAST_N_RUNS = 10  # for the "breakages in last N runs" section
HISTORY_LIMIT = 30  # rows on per-test history page

# Verdicts we care about for "broken" status.  flake & flake-from-timeout
# are reported separately -- worth surfacing but not a clean fail.
BAD_VERDICTS = {"persistent-fail", "persistent-hang", "fail", "hang"}
FLAKE_VERDICTS = {"flake", "flake-from-timeout"}

CSS = """\
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
       max-width: 1100px; margin: 2em auto; padding: 0 1em; color: #222;
       line-height: 1.4; }
h1 { margin: 0.2em 0 0.4em; font-size: 1.5em; }
h2 { margin: 1.4em 0 0.5em; font-size: 1.15em; color: #444;
     border-bottom: 1px solid #eee; padding-bottom: 0.3em; }
table { border-collapse: collapse; width: 100%; margin: 0.5em 0; font-size: 0.92em; }
th, td { text-align: left; padding: 0.35em 0.7em; border-bottom: 1px solid #eee; }
th { background: #fafafa; font-weight: 600; color: #555; }
tr:hover { background: #fbfbfb; }
.summary { display: flex; gap: 0.8em; margin: 1em 0; flex-wrap: wrap; }
.summary a.card { background: #fafafa; padding: 0.6em 1em; border-radius: 6px;
                 border: 1px solid #e8e8e8; min-width: 90px; text-align: center;
                 display: block; color: inherit; text-decoration: none; }
.summary a.card:hover { background: #f0f0f0; border-color: #ccc; }
.summary .card .num { font-size: 1.7em; font-weight: 600; }
.summary .card .label { font-size: 0.8em; color: #777; }
.summary .card.bad .num { color: #c0392b; }
.summary .card.flake .num { color: #d68910; }
.summary .card.ok .num { color: #27ae60; }
.verdict { font-size: 0.78em; padding: 0.08em 0.5em; border-radius: 3px;
           background: #eee; color: #444; display: inline-block;
           font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
.verdict.pass { background: #2ecc71; color: white; }
.verdict.skip { background: #95a5a6; color: white; }
.verdict.flake, .verdict.flake-from-timeout { background: #f39c12; color: white; }
.verdict.fail, .verdict.persistent-fail { background: #e74c3c; color: white; }
.verdict.hang, .verdict.persistent-hang { background: #8e44ad; color: white; }
.meta { color: #777; font-size: 0.85em; }
a { color: #2c5aa0; text-decoration: none; }
a:hover { text-decoration: underline; }
nav { font-size: 0.88em; margin: 0.5em 0 1em; color: #777; }
nav a + a::before { content: " / "; color: #ccc; margin: 0 0.2em; }
code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
       font-size: 0.9em; }
.sha { font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
       font-size: 0.85em; color: #555; }
details { margin: 0.4em 0; }
details > summary { cursor: pointer; padding: 0.3em 0; font-weight: 600;
                    color: #444; user-select: none; }
details > summary:hover { color: #000; }
details > summary::marker { color: #999; }
/* Modern browsers auto-open <details> when their id is the URL fragment. */
details[id]:target { background: #fffbe6; }
.test-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
             gap: 0.2em 1em; margin: 0.4em 0 0.6em; font-size: 0.85em; }
.test-grid a { white-space: nowrap; }
"""

# Templates ------------------------------------------------------------

INDEX_TMPL = """\
<!doctype html>
<html><head>
<meta charset="utf-8">
<title>fstests dashboards</title>
<style>{{ css }}</style>
<script>
// Open a <details> when its id is the URL fragment (e.g. clicked from
// a summary card).  Modern browsers do this for the initial load in
// some configurations, but not consistently for hashchange.
function _ftOpenTargetDetails() {
  var t = document.getElementById(location.hash.slice(1));
  if (t && t.tagName === 'DETAILS') t.open = true;
}
window.addEventListener('hashchange', _ftOpenTargetDetails);
window.addEventListener('load', _ftOpenTargetDetails);
</script>
</head><body>
<h1>fstests dashboards</h1>
<p class="meta">Last regenerated: {{ now }}</p>
<table>
  <tr><th>Branch</th><th>Last run</th><th>Last sha</th></tr>
  {% for b in branches %}
  <tr>
    <td><a href="{{ b.name }}/">{{ b.name }}</a></td>
    <td class="meta">{{ b.last_run or "(no runs)" }}</td>
    <td class="sha">{{ b.last_sha or "" }}</td>
  </tr>
  {% endfor %}
</table>
</body></html>
"""

