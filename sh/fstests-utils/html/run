  </tr>
  {% endfor %}
</table>
{% else %}
<p class="meta">No breakages in the last {{ last_n }} runs.</p>
{% endif %}

<h2>Recent runs</h2>
<table>
  <tr><th>sha</th><th>finished</th><th>fail</th><th>flake</th><th>hang</th></tr>
  {% for r in recent_runs %}
  <tr>
    <td><a class="sha" href="runs/{{ r.run_id }}.html">{{ r.kernel_sha }}</a></td>
    <td class="meta">{{ r.ended }}</td>
    <td>{{ (r.summary.fail or 0) + (r.summary['persistent-fail'] or 0) }}</td>
    <td>{{ (r.summary.flake or 0) + (r.summary['flake-from-timeout'] or 0) }}</td>
    <td>{{ (r.summary.hang or 0) + (r.summary['persistent-hang'] or 0) }}</td>
  </tr>
  {% endfor %}
</table>
</body></html>
"""

