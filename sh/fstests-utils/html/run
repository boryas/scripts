# Helpers --------------------------------------------------------------

def verdict_short(v):
    return {
        "pass": "P", "skip": "S",
        "flake": "f", "flake-from-timeout": "f",
        "fail": "F", "persistent-fail": "F",
        "hang": "H", "persistent-hang": "H",
    }.get(v, v[:1])


def kernel_sha(run_id):
    """Strip the '-<timestamp>' suffix from a run_id to recover the
    kernel sha for display.  Old digests with bare kernel shas (pre-
    multi-run support) are returned unchanged."""
    return run_id.split("-", 1)[0] if run_id else run_id


def load_digests(branch_dir):
    digests = []
    for p in branch_dir.glob("*.json"):
        if p.name == "history.json":
            continue
        try:
            with open(p) as f:
                d = json.load(f)
        except (json.JSONDecodeError, OSError):
            continue
        digests.append(d)
    digests.sort(key=lambda d: d.get("ended") or "", reverse=True)
    return digests


def load_history(branch_dir):
    p = branch_dir / "history.json"
    if not p.exists():
        return None
    with open(p) as f:
        return json.load(f)


def breakages_in_window(history, sha_window):
    last_n_set = set(sha_window)
    sha_index = {s: i for i, s in enumerate(sha_window)}  # for ordering
    out = {}
    for tname, tentry in history.get("tests", {}).items():
        bad = 0
        flake = 0
        verdicts_in_window = []
        for entry in tentry.get("history", []):
            sha = entry["sha"]
            if sha in last_n_set:
                v = entry["verdict"]
                verdicts_in_window.append((sha_index[sha], sha, v))
                if v in BAD_VERDICTS:
                    bad += 1
                elif v in FLAKE_VERDICTS:
                    flake += 1
        if bad > 0 or flake > 0:
            verdicts_in_window.sort()  # newest first since sha_window is newest first
            out[tname] = {
                "bad": bad,
                "flake": flake,
                "verdicts": [(sha, v) for _, sha, v in verdicts_in_window],
            }
    return out


def write_file(path, content):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)


def anchor_for(test_name):
    """Stable URL-fragment id for a test on the per-run page.  Slashes
    are not valid in fragments without escaping, so map them to '-'.
    fstests test names are [a-z]+/[0-9]+ so this is unambiguous."""
    return "t-" + test_name.replace("/", "-")


def load_run_artifacts(branch_dir, run_id, test_name):
    """Load failure artifacts (.out.bad, .dmesg) for one (run, test) tuple
    off disk.  Layout written by ssh-one.sh + test/run:

        <branch_dir>/<run_id>.details/<phase>/<group>/<num>.{out.bad,dmesg}

    Prefer the parallel phase since that's the first attempt and the one
    with the most diagnostic signal (retry runs in a fresh VM with a
    longer timeout and may pass).  Returns a dict with 'phase', 'out_bad',
    'dmesg' keys (each possibly None), or None if nothing was captured.

    Read with errors='replace' because fstests output can include
    non-utf-8 bytes from kernel splats etc.  Files are capped indirectly
    by the CSS 'max-height: 400px; overflow: auto' on pre.art -- we
    embed the full contents and let the browser scroll."""
    details_root = branch_dir / f"{run_id}.details"
    if not details_root.is_dir():
        return None
    group, num = test_name.split("/", 1)
    for phase in ("parallel", "retry"):
        phase_dir = details_root / phase / group
        out_bad = phase_dir / f"{num}.out.bad"
        dmesg = phase_dir / f"{num}.dmesg"
        if out_bad.exists() or dmesg.exists():
            return {
                "phase": phase,
                "out_bad": out_bad.read_text(errors="replace") if out_bad.exists() else None,
                "dmesg": dmesg.read_text(errors="replace") if dmesg.exists() else None,
            }
    return None


def group_latest_tests(latest, branch_dir=None, run_id=None):
    """Group a run's tests by verdict.  Returns a list of dicts suitable
    for the `groups` template variable, ordered worst→best.

    When branch_dir+run_id are provided, fail/hang/flake entries are
    enriched with on-disk artifacts (out.bad, dmesg) so the per-run
    page can render them inline.  Without those args we return just
    name+anchor (used by the branch index, which doesn't show inline
    details and doesn't need the disk reads)."""
    by_verdict = {}
    for tname, t in latest.get("tests", {}).items():
        by_verdict.setdefault(t.get("verdict", "?"), []).append(tname)
    for v in by_verdict:
        by_verdict[v].sort()

    # Merge flake/flake-from-timeout into a single bucket; same for hang
    # variants and fail variants.  Keeps the page tidy.
    def pool(*verdicts):
        out = []
        for v in verdicts:
            out += by_verdict.get(v, [])
        return sorted(out)

    show_arts = branch_dir is not None and run_id is not None
    test_entries = latest.get("tests", {})

    def skip_reason(tname):
        """Pull reason from parallel entry (preferred) or retry entry.
        Returns None for digests written before skip_reason was wired in."""
        t = test_entries.get(tname, {})
        p = t.get("parallel") or {}
        r = t.get("retry") or {}
        return p.get("skip_reason") or r.get("skip_reason")

    def enrich(tnames, with_arts):
        out = []
        for tname in tnames:
            e = {"name": tname, "anchor": anchor_for(tname)}
            if with_arts and show_arts:
                arts = load_run_artifacts(branch_dir, run_id, tname)
                if arts:
                    e.update(arts)
            out.append(e)
        return out

    skip_tests = pool("skip")
    # Bucket skips by reason for the taxonomy view.  When no digest carries
    # skip_reason (old runs pre-wiring), buckets stays empty and the
    # template falls back to the plain test grid.
    buckets = {}
    for tname in skip_tests:
        r = skip_reason(tname)
        if r:
            buckets.setdefault(r, []).append(tname)
    # Sorted: largest bucket first, then alphabetical reason for stability.
    skip_buckets = [
        {"reason": r, "tests": sorted(ts)}
        for r, ts in sorted(buckets.items(), key=lambda x: (-len(x[1]), x[0]))
    ]

    # Split bad-verdict tests into "known" (have a category in tests.yaml)
    # and "unknown" (the real signal).  Known entries are kept off the
    # main fail/hang buckets and rendered in a dedicated section grouped
    # by category.
    bad_pool = pool("fail", "persistent-fail", "hang", "persistent-hang")
    bad_unknown = [t for t in bad_pool if t not in KNOWN_FAILURES]
    bad_known = [t for t in bad_pool if t in KNOWN_FAILURES]

    # Transition detection: if a known-failures test produced a good or
    # flake verdict in this run, surface it so we can decide whether to
    # demote the entry.  Iterate the YAML once so each listed test gets
    # checked, not just the ones currently bad.
    transitions = []
    for tname, meta in KNOWN_FAILURES.items():
        v = test_entries.get(tname, {}).get("verdict")
        if v in GOOD_VERDICTS or v in FLAKE_VERDICTS:
            transitions.append({"name": tname, "anchor": anchor_for(tname),
                                "verdict": v,
                                "category": meta.get("category", ""),
                                "status": meta.get("status", "")})
    transitions.sort(key=lambda x: x["name"])

    # Group known-bad by category for the bucket.
    known_by_cat = {}
    for tname in bad_known:
        cat = KNOWN_FAILURES[tname].get("category", "uncategorized")
        known_by_cat.setdefault(cat, []).append(tname)
    known_groups = []
    for cat, tnames in sorted(known_by_cat.items(), key=lambda x: (-len(x[1]), x[0])):
        rows = []
        for tname in sorted(tnames):
            meta = KNOWN_FAILURES[tname]
            rows.append({"name": tname, "anchor": anchor_for(tname),
                         "status": meta.get("status", ""),
                         "explanation": meta.get("explanation", "").strip(),
                         "investigated": meta.get("investigated", "")})
        known_groups.append({"category": cat, "tests": rows})

    # Split bad-unknown back by verdict for the fail/hang buckets.
    unknown_set = set(bad_unknown)
    def filt(names):
        return [n for n in names if n in unknown_set]

    return [
        {"key": "fail",  "label": "fail",  "open": True,  "with_details": show_arts,
         "tests": enrich(filt(pool("fail", "persistent-fail")), True)},
        {"key": "hang",  "label": "hang",  "open": True,  "with_details": show_arts,
         "tests": enrich(filt(pool("hang", "persistent-hang")), True)},
        {"key": "flake", "label": "flake", "open": True,  "with_details": show_arts,
         "tests": enrich(pool("flake", "flake-from-timeout"), True)},
        {"key": "known", "label": "known failures", "open": False, "with_details": False,
         "tests": enrich(bad_known, False),
         "known_groups": known_groups,
         "transitions": transitions},
        {"key": "skip",  "label": "skip",  "open": False, "with_details": False,
         "tests": enrich(skip_tests, False),
         "skip_buckets": skip_buckets},
        {"key": "pass",  "label": "pass",  "open": False, "with_details": False,
         "tests": enrich(pool("pass"), False)},
    ]


def render_branch(env, branch, branch_dir, out_dir):
    digests = load_digests(branch_dir)
    history = load_history(branch_dir)
    if not digests or not history:
        return None

    latest = digests[0]
    sha_window = [d["sha"] for d in digests[:LAST_N_RUNS]]
    breakages = breakages_in_window(history, sha_window)
    # Sort alphabetically by test id so scanning is predictable (the
    # breakage counts are in the row, so the matrix isn't the search key).
    sorted_breakages = sorted(breakages.items(), key=lambda kv: kv[0])

    recent_runs = [
        {"run_id": d["sha"], "kernel_sha": kernel_sha(d["sha"]),
         "ended": d.get("ended", ""), "summary": d.get("summary", {})}
        for d in digests[:LAST_N_RUNS]
    ]

    branch_out = out_dir / branch
    branch_out.mkdir(parents=True, exist_ok=True)

    # Window date range for clearer labelling: oldest .. newest of the
    # actual digests we have in hand (not just history.json shas, which
    # can include pre-digest legacy entries).
    window_newest = digests[0].get("ended", "?")
    window_oldest = digests[min(len(digests), LAST_N_RUNS) - 1].get("ended", "?")

    groups = group_latest_tests(latest)

    # Global counts: # test names with at least one of that verdict
    # in the window.  (vs per-run counts which double-count across runs.)
    global_counts = {
        "fail":  sum(1 for _, info in breakages.items() if info["bad"]),
        "hang":  sum(1 for _, info in breakages.items()
                     if any(v in ("hang", "persistent-hang")
                            for _, v in info["verdicts"])),
        "flake": sum(1 for _, info in breakages.items() if info["flake"]),
    }

    branch_html = env.get_template("branch").render(
        css=CSS, branch=branch,
        latest_sha=kernel_sha(latest["sha"]),
        latest_run_id=latest["sha"],
        latest_ts=latest.get("ended", "?"),
        run_count=len(sha_window),
        window_oldest=window_oldest,
        window_newest=window_newest,
        summary=adjusted_summary(latest),
        groups=groups,
        last_n=LAST_N_RUNS,
        breakages=sorted_breakages,
        global_counts=global_counts,
        recent_runs=recent_runs,
        verdict_short=verdict_short,
    )
    write_file(branch_out / "index.html", branch_html)

    # Per-test history pages for *every* test in the branch's history.
    # Cheap (a few MB of static HTML) and lets every test name in the
    # grouped lists / breakages table be a working link.  Sort by `ts`
    # descending so newest is always on top (state/run.py's insert-at-0
    # is mtime-sorted, which can be wrong if digests were backfilled).
    for tname, tentry in history.get("tests", {}).items():
        history_entries = sorted(
            tentry["history"], key=lambda e: e.get("ts", ""), reverse=True
        )[:HISTORY_LIMIT]
        # Inject kernel_sha for display; e["sha"] stays as the run_id for
        # link targets.
        for e in history_entries:
            e["kernel_sha"] = kernel_sha(e.get("sha", ""))
        page = env.get_template("test").render(
            css=CSS, branch=branch, test_name=tname,
            entries=history_entries, limit=HISTORY_LIMIT,
        )
        write_file(branch_out / "tests" / f"{tname}.html", page)

    # Per-run pages: one page per <run_id>.json, showing all tests for
    # that run grouped by verdict.  run_id includes a timestamp suffix
    # so multiple runs against the same kernel sha get their own page.
    for d in digests:
        run_id = d["sha"]  # legacy field name; actually carries the run_id
        page = env.get_template("run").render(
            css=CSS, branch=branch,
            sha=kernel_sha(run_id), run_id=run_id,
            ts=d.get("ended", "?"),
            summary=adjusted_summary(d),
            # Pass branch_dir + run_id so fail/hang/flake entries get
            # enriched with the on-disk .out.bad / .dmesg artifacts.
            # Branch page (line 438 above) deliberately does not pass
            # these -- it shows test names only, so we don't pay the
            # disk-read cost on the index.
            groups=group_latest_tests(d, branch_dir, run_id),
        )
        write_file(branch_out / "runs" / f"{run_id}.html", page)

    return {
        "name": branch,
        "last_run": latest.get("ended", "?"),
        "last_sha": latest["sha"],
    }


def main():
    import datetime
    branches = sys.argv[1:] or None
    if not RESULTS_DIR.is_dir():
        print(f"no results dir: {RESULTS_DIR}", file=sys.stderr)
        sys.exit(1)

    if branches is None:
        branches = [p.name for p in RESULTS_DIR.iterdir()
                    if p.is_dir() and p.name != "html"
                    and (p / "history.json").exists()]
    if not branches:
        print("no branches with history.json found", file=sys.stderr)
        sys.exit(1)

    HTML_DIR.mkdir(parents=True, exist_ok=True)
    env = Environment(
        loader=BaseLoader(),
        autoescape=select_autoescape(["html"]),
    )
    env.loader = type("L", (BaseLoader,), {
        "get_source": lambda self, env, name: ({
            "index": INDEX_TMPL, "branch": BRANCH_TMPL,
            "test": TEST_TMPL, "run": RUN_TMPL,
        }[name], name, lambda: True)
    })()

    rendered = []
    for b in branches:
        info = render_branch(env, b, RESULTS_DIR / b, HTML_DIR)
        if info:
            rendered.append(info)
            print(f"wrote {HTML_DIR}/{b}/")

    rendered.sort(key=lambda i: i["last_run"], reverse=True)
    index_html = env.get_template("index").render(
        css=CSS,
        now=datetime.datetime.now(datetime.timezone.utc).astimezone()
            .strftime("%Y-%m-%d %H:%M %Z"),
        branches=rendered,
    )
    write_file(HTML_DIR / "index.html", index_html)
    print(f"wrote {HTML_DIR}/index.html")

    target = os.environ.get("HTML_RSYNC_TARGET")
    if target:
        print(f"rsync to {target} ...")
        subprocess.run(
            ["rsync", "-az", "--delete",
             f"{HTML_DIR}/", target],
            check=True,
        )


if __name__ == "__main__":
    main()
