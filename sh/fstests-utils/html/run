  <div class="card bad"><div class="num">{{ global_counts.hang }}</div><div class="label">ever-hung</div></div>
  <div class="card flake"><div class="num">{{ global_counts.flake }}</div><div class="label">ever-flaked</div></div>
</div>
{% if breakages %}
